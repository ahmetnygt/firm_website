                    }
                },
                {
                    "@type": "Question",
                    "name": "Otobüs bagaj hakkım kaç kilogramdır?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Konforlu seyahatiniz için her yolcumuzun bagaj bölümünde 30 kg'a kadar ücretsiz yük taşıma hakkı bulunmaktadır. Değerli eşyalarınızı içeren el bagajlarınızı ise araç içine alabilirsiniz."
                    }
