        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "İnternetten ucuz otobüs bileti nasıl alınır?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Web sitemiz üzerinden kalkış ve varış noktalarınızı seçerek güncel sefer saatlerini sorgulayabilir, size en uygun ve ucuz otobüs biletini 3D Secure güvenli ödeme altyapısıyla saniyeler içinde satın alabilirsiniz."
                    }
                },
                {
                    "@type": "Question",
