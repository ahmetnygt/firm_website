extends layout

block css
    style.
        /* Firma Renkleri */
        :root {
            --primary-color: #{tenant.primaryColor || '#0088CC'};
            --accent-color: #{tenant.accentColor || '#D94E1E'};
        }

        /* Modern Arama Kartı */
        .hero-search-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 1rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        .section-title {
            font-weight: 800;
            color: #2c3e50;
            position: relative;
            padding-bottom: 0.5rem;
            display: inline-block;
            text-transform: uppercase;
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background-color: var(--accent-color);
            border-radius: 2px;
        }

        /* 4'lü ve 3'lü İkonlar */
        .attr-icon {
            color: var(--accent-color);
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
            display: inline-block;
        }

        /* Fiyatlı Rota Kartları (Kampanyalarımız) */
        .price-card {
            border-radius: 0.5rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid #eaeaea;
            background: #fff;
        }
        .price-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
            border-color: var(--accent-color);
        }
        .old-price { text-decoration: line-through; color: #a0a0a0; font-size: 1.1rem; }
        .new-price { color: var(--accent-color); font-size: 2.5rem; font-weight: 800; }
        .feature-list i { color: #27ae60; margin-right: 0.5rem; }

        /* Swap (Yön Değiştir) Butonu Animasyonu */
        .swap-btn { transition: transform 0.3s ease; }
        .swap-btn:active { transform: rotate(180deg) scale(0.9); }

block content
    // 1) HERO ALANI (Sola Yaslı Form)
    section.hero.position-relative(style="min-height: 80vh; display: flex; align-items: center;")
        .hero-bg.position-absolute.w-100.h-100.top-0.start-0(style="z-index: -2;")
            picture
                source(media="(min-width:992px)" srcset="/images/hero-bg.webp" type="image/webp")
                source(media="(min-width:768px)" srcset="/images/hero-bg.webp" type="image/webp")
                img.img-fluid.w-100.h-100.object-fit-cover(src="/images/hero-bg.webp" alt=`${tenant.name} Otobüs Yolculuğu` loading="eager" fetchpriority="high")
        
        .hero-overlay.position-absolute.w-100.h-100.top-0.start-0(style="background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%); z-index: -1;")
        
        .container.position-relative.py-5
            .text-white.mb-4
                h1.display-5.fw-bold.mb-2.text-shadow Dakik ve Güvenli Yolculuk
                p.lead.fw-normal.text-light Trakya'nın en güvenilir filosuyla konforlu seyahatin tadını çıkarın.
            .row
                .col-xl-5.col-lg-6.col-md-8.mt-5.mt-lg-0
                    .hero-search-card.p-4
                        form#searchForm
                            .mb-3
                                label.form-label.fw-bold.text-dark Kalkış - Varış Noktası
                                .d-flex.align-items-center.gap-2
                                    .flex-grow-1.searchable-select(style="width: 40%;")
                                        select.form-select.form-select-lg#from(required)
                                            option(disabled selected value="") Nereden
                                            each c in cities
                                                option(value=c.placeId)= c.title
                                    
                                    button.btn.btn-outline-primary.rounded-circle.swap-btn.flex-shrink-0#swapCities(type="button" style="width: 42px; height: 42px; padding: 0;" aria-label="Yönleri Değiştir")
                                        i.bi.bi-arrow-left-right
                                    
                                    .flex-grow-1.searchable-select(style="width: 40%;")
                                        select.form-select.form-select-lg#to(required)
                                            option(disabled selected value="") Nereye
                                            each c in cities
                                                option(value=c.placeId)= c.title
                            
                            .mb-4
                                label.form-label.fw-bold.text-dark Yolculuk Tarihi
                                .input-group.input-group-lg
                                    input.form-control.bg-white#date(type="text" required placeholder="Tarih Seçin")
                                    span.input-group-text.bg-white
                                        i.bi.bi-calendar3.text-primary
                            
                            .d-flex.gap-2
                                button.btn.btn-outline-secondary.today.fw-medium.flex-fill(type="button") Bugün
                                button.btn.btn-outline-secondary.tomorrow.fw-medium.flex-fill(type="button") Yarın
                                button.btn.btn-primary.btn-lg.fw-bold.flex-fill(type="submit" style="flex: 2;")
                                    | Sefer Ara

    // 2) 4 TEMEL ÖZELLİK (bg-white)
    section.py-5.bg-white
        .container.py-3
            .row.text-center.g-4
                .col-6.col-md-3
                    i.bi.bi-car-front-fill.attr-icon
                    h3.h6.fw-bold.text-dark KONFORLU SEYAHAT
                .col-6.col-md-3
                    i.bi.bi-emoji-smile-fill.attr-icon
                    h3.h6.fw-bold.text-dark GÜLER YÜZLÜ EKİP
                .col-6.col-md-3
                    i.bi.bi-clock-fill.attr-icon
                    h3.h6.fw-bold.text-dark ZAMANINDA VARIŞ
                .col-6.col-md-3
                    i.bi.bi-fan.attr-icon
                    h3.h6.fw-bold.text-dark KLİMALI ARAÇLAR

    // 3) KAMPANYALARIMIZ (bg-light)
    section.py-5.bg-light
        .container.py-4
            .text-center.mb-5
                h2.section-title KAMPANYALARIMIZ
                p.text-muted.mt-3 İndirimli bilet fiyatlarıyla konforlu seyahat fırsatlarını kaçırmayın.
            .row.g-4.justify-content-center
                // Kart 1
                .col-md-4
                    .card.price-card.h-100.p-4.text-center
                        h3.h5.fw-bold.mb-3 ÇORLU > KADIKÖY
                        .mb-4
                            span.old-price.me-2 600₺
                            span.new-price 450
                                small.fs-5 ₺
                        ul.list-unstyled.feature-list.text-start.mx-auto.mb-0(style="max-width: 180px;")
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Konforlu Seyahat
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Güler Yüzlü Ekip
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Zamanında Varış
                            li
                                i.bi.bi-check-circle-fill
                                span.text-muted Klimalı Araç

                // Kart 2
                .col-md-4
                    .card.price-card.h-100.p-4.text-center
                        h3.h5.fw-bold.mb-3 BEYLİKDÜZÜ > ÇANAKKALE
                        .mb-4
                            span.old-price.me-2 900₺
                            span.new-price 750
                                small.fs-5 ₺
                        ul.list-unstyled.feature-list.text-start.mx-auto.mb-0(style="max-width: 180px;")
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Konforlu Seyahat
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Güler Yüzlü Ekip
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Zamanında Varış
                            li
                                i.bi.bi-check-circle-fill
                                span.text-muted Klimalı Araç

                // Kart 3
                .col-md-4
                    .card.price-card.h-100.p-4.text-center
                        h3.h5.fw-bold.mb-3 BEYLİKDÜZÜ > GELİBOLU
                        .mb-4
                            span.old-price.me-2 800₺
                            span.new-price 650
                                small.fs-5 ₺
                        ul.list-unstyled.feature-list.text-start.mx-auto.mb-0(style="max-width: 180px;")
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Konforlu Seyahat
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Güler Yüzlü Ekip
                            li.mb-2
                                i.bi.bi-check-circle-fill
                                span.text-muted Zamanında Varış
                            li
                                i.bi.bi-check-circle-fill
                                span.text-muted Klimalı Araç

    // 3) POPÜLER ŞEHİRLER
    section.py-3.bg-light
        .container.py-4
            .text-center.mb-5
                h2.section-title POPÜLER ŞEHİRLER
            .row.g-3
                .col-md-6
                    .row.g-3
                        .col-12
                            a.card.city-card.small.text-white.text-decoration-none(href="#")
                                img.card-img(src="/images/route-2.png" alt="Eceabat Kadıköy" loading="lazy")
                                .card-img-overlay.city-card-overlay.d-flex.justify-content-center
                                    h3.h5.mb-0.fw-bold.text-white.text-shadow ECEABAT-KADIKÖY
                        .col-12
                            a.card.city-card.small.text-white.text-decoration-none(href="#")
                                img.card-img(src="/images/route-3.png" alt="Çorlu İstanbul" loading="lazy")
                                .card-img-overlay.city-card-overlay.d-flex.justify-content-center
                                    h3.h5.mb-0.fw-bold.text-white.text-shadow ÇORLU-İSTANBUL
                .col-md-6
                    .row.g-3
                        .col-12
                            a.card.city-card.small.text-white.text-decoration-none(href="#")
                                img.card-img(src="/images/route-2.png" alt="Eceabat Kadıköy" loading="lazy")
                                .card-img-overlay.city-card-overlay.d-flex.justify-content-center
                                    h3.h5.mb-0.fw-bold.text-white.text-shadow ECEABAT-KADIKÖY
                        .col-12
                            a.card.city-card.small.text-white.text-decoration-none(href="#")
                                img.card-img(src="/images/route-3.png" alt="Çorlu İstanbul" loading="lazy")
                                .card-img-overlay.city-card-overlay.d-flex.justify-content-center
                                    h3.h5.mb-0.fw-bold.text-white.text-shadow ÇORLU-İSTANBUL


    // 4) DURAKLARIMIZ (API'den Çekilen Dinamik Şehirler - bg-white)
    if cities && cities.length
        section.py-5.bg-white
            .container.py-4
                .text-center.mb-5
                    h2.section-title DURAKLARIMIZ
                    p.text-muted.mt-3 Yolcularımızı güvenle ulaştırdığımız tüm il ve ilçe duraklarımız.
                .d-flex.flex-wrap.justify-content-center.gap-3.mt-4
                    each c in cities
                        span.btn.btn-outline-primary.rounded-pill.px-4.py-2.fw-medium(style="cursor: default;")
                            i.bi.bi-geo-alt-fill.me-2
                            | #{c.title}

    // 5) SIKÇA SORULAN SORULAR (SEO CANAVARI FAQ BÖLÜMÜ - bg-light)
    section.py-5.bg-light
        .container.py-4
            .text-center.mb-5
                h2.section-title SIKÇA SORULAN SORULAR
                p.text-muted.mt-3 Yolcularımızın en çok merak ettiği konular ve seyahat kurallarımız.
            
            .row.justify-content-center
                .col-lg-8
                    .accordion.accordion-flush.shadow-sm.rounded-4.border.overflow-hidden.bg-white#seoFaq
                        - 
                            var faqs = [
                                {q: "İnternetten ucuz otobüs bileti nasıl alınır?", a: "Web sitemiz üzerinden kalkış ve varış noktalarınızı seçerek güncel sefer saatlerini sorgulayabilir, size en uygun ve ucuz otobüs biletini 3D Secure güvenli ödeme altyapısıyla saniyeler içinde satın alabilirsiniz."},
                                {q: "Bilet iptal ve iade koşulları nelerdir?", a: "Satın aldığınız online otobüs biletlerini, sefer saatine 24 saat kalana kadar web sitemizdeki 'Biletlerim' menüsünden kesintisiz olarak iptal edebilir ve kredi kartınıza tam iade alabilirsiniz."},
                                {q: "Otobüs bagaj hakkım kaç kilogramdır?", a: "Konforlu seyahatiniz için her yolcumuzun bagaj bölümünde 30 kg'a kadar ücretsiz yük taşıma hakkı bulunmaktadır. Değerli eşyalarınızı içeren el bagajlarınızı ise araç içine alabilirsiniz."},
                                {q: "Evcil hayvanımla otobüs yolculuğu yapabilir miyim?", a: "Evet, aşı karnesi tam ve özel taşıma çantası içinde olan küçük evcil hayvanlarınızla (kedi, küçük ırk köpek, kuş vb.) güvenle seyahat edebilirsiniz. Detaylı bilgi için müşteri hizmetlerimizle iletişime geçebilirsiniz."}
                            ]
                        each item, index in faqs
                            .accordion-item.border-bottom
                                h3.accordion-header
                                    button.accordion-button.collapsed.fw-bold.text-dark(type="button" data-bs-toggle="collapse" data-bs-target=`#faq${index}` aria-expanded="false")= item.q
                                div(id=`faq${index}` class="accordion-collapse collapse" data-bs-parent="#seoFaq")
                                    .accordion-body.text-muted.lh-lg= item.a

    // 6) ALT GÜVENLİK/BİLGİ ALANI (bg-white)
    section.py-5.bg-white
        .container.py-3
            .row.g-4
                .col-md-4.d-flex.align-items-start.justify-content-center.justify-content-md-start
                    .attr-icon.me-3
                        i.bi.bi-shield-check
                    div
                        h4.h6.fw-bold.text-dark GÜVENLİ ÖDEME
                        p.small.text-muted.mb-0 Tüm ödemeleriniz SSL ile güvence altına alınmıştır.
                .col-md-4.d-flex.align-items-start.justify-content-center.justify-content-md-start
                    .attr-icon.me-3
                        i.bi.bi-people-fill
                    div
                        h4.h6.fw-bold.text-dark TECRÜBELİ EKİP
                        p.small.text-muted.mb-0 Alanında tecrübeli şoförlerimizle güvenle seyahat edin.
                .col-md-4.d-flex.align-items-start.justify-content-center.justify-content-md-start
                    .attr-icon.me-3
                        i.bi.bi-bus-front-fill
                    div
                        h4.h6.fw-bold.text-dark KONFORLU SEYAHAT
                        p.small.text-muted.mb-0 Tüm seferlerimiz sizin rahat etmeniz için özel planlanır.

block js
    // JSON-LD SCHEMA.ORG (GOOGLE'I ÇILDIRTAN KISIM)
