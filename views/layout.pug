doctype html
html(lang="tr")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        title= tenant.name + " – Güvenli ve Hızlı Otobüs Bileti"
        meta(name="description" content=`${tenant.name} ile Türkiye'nin her yerine online, ucuz ve güvenli otobüs bileti al.`)
        
        //- Kütüphaneler
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css")
        link(rel="stylesheet" href="/css/style.css")

        //- Dinamik Firma Renkleri (Tüm sayfalara etki etsin diye buraya koyduk)
        style.
            :root {
                --primary-color: #{tenant.primaryColor || '#0088CC'};
                --accent-color: #{tenant.accentColor || '#D94E1E'};
                --bs-primary: var(--primary-color);
                --bs-primary-rgb: 0, 136, 204; /* Fallback */
            }
            .bg-primary { background-color: var(--primary-color) !important; }
            .text-primary { color: var(--primary-color) !important; }
            .btn-primary { 
                background-color: var(--primary-color); 
                border-color: var(--primary-color); 
            }
            .btn-primary:hover {
                background-color: color-mix(in srgb, var(--primary-color) 85%, black);
                border-color: color-mix(in srgb, var(--primary-color) 85%, black);
            }
            .btn-outline-primary {
                color: var(--primary-color);
                border-color: var(--primary-color);
            }
            .btn-outline-primary:hover {
                background-color: var(--primary-color);
                color: #fff;
            }

        block css

        script(type="application/ld+json").
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "!{tenant.name}",
                "url": "!{tenant.apiBase}",
                "logo": "!{tenant.logo}",
                "telephone": "!{tenant.phone}"
            }
    
    body.bg-light
        // 1) TOP BAR (Üst İnce Şerit)
        .top-bar.text-white.small(style="background-color: var(--primary-color);")
            .container.d-flex.justify-content-end.align-items-center.py-2.gap-3
                span.fw-medium 
                    i.bi.bi-headset.me-1 
                    | Müşteri Hizmetleri
                if tenant.phone
                    a.text-white.text-decoration-none.fw-bold(href="tel:" + tenant.phone.replace(/\s/g, ""))
                        i.bi.bi-telephone.me-1
                        = tenant.phone

        // 2) NAVBAR
        nav.navbar.navbar-expand-lg.navbar-light.bg-white.shadow-sm.sticky-top
            .container
                a.navbar-brand.py-1(href="/")
                    img(src=`/images/logo.png` height="65" alt=tenant.name loading="lazy" style="object-fit: contain;")
                
                button.navbar-toggler.border-0.shadow-none(type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Menü")
                    span.navbar-toggler-icon
                
                #mainNav.collapse.navbar-collapse
                    ul.navbar-nav.mx-auto.mb-2.mb-lg-0.fw-medium
                        li.nav-item: a.nav-link.fs-6.ms-2.text-dark(href="#") Kurumsal
                        li.nav-item: a.nav-link.fs-6.ms-2.text-dark(href="#") Şubelerimiz
                        li.nav-item: a.nav-link.fs-6.ms-2.text-dark(href="#") Kampanyalar
                        li.nav-item: a.nav-link.fs-6.ms-2.text-dark(href="#") İletişim
                    
                    .d-flex.gap-2.align-items-center#auth-buttons.mt-3.mt-lg-0
                        if user
                            // --- GİRİŞ YAPILMIŞSA ---
                            .dropdown
                                button.btn.btn-light.border.dropdown-toggle.d-flex.align-items-center.gap-2.rounded-pill.px-3(type="button" data-bs-toggle="dropdown")
                                    .bg-primary.text-white.rounded-circle.d-flex.align-items-center.justify-content-center(style="width:28px; height:28px;")
                                        i.bi.bi-person-fill
                                    .text-start.lh-1
                                        .small.text-muted Hoş Geldiniz
                                        .fw-bold.fs-6= user.name + " " + user.surname
                                
                                ul.dropdown-menu.dropdown-menu-end.shadow-lg.border-0.mt-2.rounded-4
                                    li
                                        a.dropdown-item.py-2(href="/profile")
                                            i.bi.bi-person-gear.me-2.text-muted
                                            | Hesabım
                                    li
                                        a.dropdown-item.py-2(href="/my-tickets")
                                            i.bi.bi-ticket-perforated.me-2.text-muted
                                            | Biletlerim
                                    li
                                        hr.dropdown-divider
                                    li
                                        a.dropdown-item.text-danger.py-2(href="/logout")
                                            i.bi.bi-box-arrow-right.me-2
                                            | Çıkış Yap
                        else
                            // --- GİRİŞ YAPILMAMIŞSA ---
                            button.btn.btn-outline-primary.rounded-pill.px-4.fw-medium(type="button" data-bs-toggle="modal" data-bs-target="#registerModal") Kayıt Ol
                            button.btn.btn-primary.rounded-pill.px-4.fw-medium(type="button" data-bs-toggle="modal" data-bs-target="#loginModal") Giriş Yap

        // 3) ANA İÇERİK
        main
            block content

        // 4) FOOTER
        footer.bg-dark.text-white.py-5.mt-auto
            .container
                .row.align-items-center
                    .col-md-6.mb-4.mb-md-0.text-center.text-md-start
                        img.mb-3(src=`/images/logo.png` height="45" alt=tenant.name loading="lazy" style="filter: brightness(0) invert(1); opacity: 0.8;")
                        p.small.text-white-50.mb-0 © #{new Date().getFullYear()} #{tenant.name}. Tüm hakları saklıdır.
                    
                    .col-md-6.text-center.text-md-end
                        .d-flex.gap-2.justify-content-center.justify-content-md-end.mb-3
                            if tenant.phone
                                a.btn.btn-outline-light.btn-sm.rounded-pill.px-3(href="https://wa.me/" + tenant.phone.replace(/\s/g, "") target="_blank")
                                    i.bi.bi-whatsapp.me-1
                                    | WhatsApp
                                a.btn.btn-outline-light.btn-sm.rounded-pill.px-3(href="tel:" + tenant.phone.replace(/\s/g, ""))
                                    i.bi.bi-telephone.me-1
                                    | Ara
                        
                        .small
                            a.text-white-50.text-decoration-none.me-3.custom-link-hover(href="#") Gizlilik
                            a.text-white-50.text-decoration-none.me-3.custom-link-hover(href="#") Kullanım Koşulları
                            a.text-white-50.text-decoration-none.custom-link-hover(href="#") Çerez Politikası

        // --- MODALLAR ---

        // 1) GİRİŞ MODALI
        .modal.fade#loginModal(tabindex="-1" aria-hidden="true")
            .modal-dialog.modal-dialog-centered
                .modal-content.border-0.shadow-lg.rounded-4
                    .modal-header.border-0.pb-0
                        button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Kapat")
                    .modal-body.px-4.px-md-5.pb-5
                        .text-center.mb-4
                            h4.fw-bold Üye Girişi
                            p.text-muted.small Biletlerinize hızlıca ulaşın
                        
                        form#loginForm
                            .mb-3
                                label.form-label.text-muted.small.fw-medium(for="loginIdNumber") T.C. Kimlik Numarası
                                .input-group.input-group-lg
                                    span.input-group-text.bg-white
                                        i.bi.bi-person-badge.text-muted
                                    input.form-control.border-start-0.ps-0#loginIdNumber(type="text" name="idNumber" placeholder="11 haneli TC kimlik no" maxlength="11" required)
                            
                            .mb-4
                                label.form-label.text-muted.small.fw-medium(for="loginPassword") Şifre
                                .input-group.input-group-lg
                                    span.input-group-text.bg-white
                                        i.bi.bi-key.text-muted
                                    input.form-control.border-start-0.ps-0#loginPassword(type="password" name="password" placeholder="******" required)
                            
                            .d-grid
                                button.btn.btn-primary.btn-lg.rounded-pill.fw-bold(type="submit")
                                    span.text-btn Giriş Yap
                                    span.spinner-border.spinner-border-sm.d-none(role="status" aria-hidden="true")

                        .text-center.mt-4
                            p.small.text-muted.mb-1 Henüz üye değil misiniz?
                            a.text-primary.fw-bold.text-decoration-none(href="#" data-bs-target="#registerModal" data-bs-toggle="modal") Hemen Kayıt Ol

        // 2) KAYIT MODALI
        .modal.fade#registerModal(tabindex="-1" aria-hidden="true")
            .modal-dialog.modal-dialog-centered
                .modal-content.border-0.shadow-lg.rounded-4
                    .modal-header.border-0.pb-0
                        button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Kapat")
                    .modal-body.px-4.px-md-5.pb-5
                        .text-center.mb-4
                            h4.fw-bold Yeni Üyelik
                            p.text-muted.small Avantajlardan yararlanmak için katılın
                        
                        form#registerForm
                            .row.g-3.mb-3
                                .col-6
                                    label.form-label.text-muted.small.fw-medium Adınız
                                    input.form-control.form-control-lg.bg-light.border-0(type="text" name="name" required)
                                .col-6
                                    label.form-label.text-muted.small.fw-medium Soyadınız
                                    input.form-control.form-control-lg.bg-light.border-0(type="text" name="surname" required)

                            .mb-3
                                label.form-label.text-muted.small.fw-medium T.C. Kimlik Numarası
                                input.form-control.form-control-lg.bg-light.border-0(type="text" name="idNumber" maxlength="11" required)

                            .mb-3
                                label.form-label.text-muted.small.fw-medium Telefon Numarası
                                input.form-control.form-control-lg.bg-light.border-0(type="tel" name="phone" placeholder="5XX XXX XX XX" maxlength="10" required)

                            .mb-3
                                label.form-label.text-muted.small.fw-medium E-Posta Adresi
                                input.form-control.form-control-lg.bg-light.border-0(type="email" name="email" placeholder="ornek@mail.com")

                            .mb-3
                                label.form-label.text-muted.small.fw-medium Cinsiyet
                                .d-flex.gap-4.mt-1
                                    .form-check
                                        input.form-check-input(type="radio" name="gender" id="genderM" value="m" checked)
                                        label.form-check-label(for="genderM") Erkek
                                    .form-check
                                        input.form-check-input(type="radio" name="gender" id="genderF" value="f")
                                        label.form-check-label(for="genderF") Kadın

                            .mb-4
                                label.form-label.text-muted.small.fw-medium Şifre Belirleyin
                                input.form-control.form-control-lg.bg-light.border-0(type="password" name="password" placeholder="En az 6 karakter" required)

                            .d-grid
                                button.btn.btn-primary.btn-lg.rounded-pill.fw-bold(type="submit")
                                    span.text-btn Kaydı Tamamla
                                    span.spinner-border.spinner-border-sm.d-none(role="status" aria-hidden="true")

                        .text-center.mt-4
                            p.small.text-muted.mb-1 Zaten üye misiniz?
                            a.text-primary.fw-bold.text-decoration-none(href="#" data-bs-target="#loginModal" data-bs-toggle="modal") Giriş Yap

        //- SCRIPTS
        script(src="https://code.jquery.com/jquery-3.7.1.min.js")
        script(src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/js/all.min.js")
        script(src="https://cdn.jsdelivr.net/npm/flatpickr")
        //- Tükçe takvim dil paketi
        script(src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/tr.js")
        
        script(src="/js/script.js")
        script(src="/js/searchable-select.js")
        block js